# Server-only. Never expose this value through NEXT_PUBLIC_* variables.
OPENAI_API_KEY=replace_with_server_only_key
OPENAI_TASK_MODEL=gpt-5.6-terra
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional content-free custom events. Automatic page-view tracking stays disabled.
NEXT_PUBLIC_ENABLE_ANALYTICS=false
