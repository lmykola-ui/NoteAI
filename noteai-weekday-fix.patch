+++ b/src/server/openai/parseUserMessage.test.ts
@@ -0,0 +1,58 @@
+import { describe, expect, it } from "vitest";
+import {
+  buildParseUserMessage,
+  buildWeekdayReferenceBlock,
+} from "./parseUserMessage.mjs";
+
+describe("buildWeekdayReferenceBlock", () => {
+  it("maps every day of a Sunday-anchored week to the correct date and label", () => {
+    const block = buildWeekdayReferenceBlock("2026-07-19");
+    const lines = block.split("\n");
+
+    expect(lines[0]).toBe("2026-07-19 = неділя (сьогодні)");
+    expect(lines[1]).toBe("2026-07-20 = понеділок (завтра)");
+    expect(lines[2]).toBe("2026-07-21 = вівторок");
+    expect(lines[3]).toBe("2026-07-22 = середа");
+    expect(lines[4]).toBe("2026-07-23 = четвер");
+    expect(lines[5]).toBe("2026-07-24 = п’ятниця");
+    expect(lines[6]).toBe("2026-07-25 = субота");
+    expect(lines[7]).toBe("2026-07-26 = неділя");
+    // The following-week row must exist so "наступний понеділок" phrasing
+    // always resolves to a same-week date, never accidentally the row below.
+    expect(lines[8]).toBe("2026-07-27 = понеділок");
+  });
+
+  it("does not drift by one day across a month boundary", () => {
+    const block = buildWeekdayReferenceBlock("2026-07-31");
+    const lines = block.split("\n");
+
+    expect(lines[0]).toBe("2026-07-31 = п’ятниця (сьогодні)");
+    expect(lines[1]).toBe("2026-08-01 = субота (завтра)");
+    expect(lines[2]).toBe("2026-08-02 = неділя");
+  });
+
+  it("covers at least two weeks so every weekday name has an unambiguous row", () => {
+    const block = buildWeekdayReferenceBlock("2026-07-19");
+    const lines = block.split("\n");
+
+    expect(lines).toHaveLength(14);
+  });
+});
+
+describe("buildParseUserMessage", () => {
+  it("embeds the weekday table between the date fields and the note text", () => {
+    const message = buildParseUserMessage({
+      today: "2026-07-19",
+      timeZone: "Europe/Warsaw",
+      text: "У понеділок оновити резюме",
+    });
+
+    expect(message).toBe(
+      "Локальна дата: 2026-07-19\n" +
+        "Часовий пояс: Europe/Warsaw\n" +
+        "Дні тижня (використовуй лише цю таблицю для будь-якого дня тижня; не обчислюй день тижня самостійно):\n" +
+        `${buildWeekdayReferenceBlock("2026-07-19")}\n` +
+        "Нотатка: У понеділок оновити резюме",
+    );
+  });
+});
