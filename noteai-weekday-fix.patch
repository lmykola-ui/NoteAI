@@ -0,0 +1,56 @@
+const WEEKDAY_NAMES_UK = [
+  "неділя",
+  "понеділок",
+  "вівторок",
+  "середа",
+  "четвер",
+  "п’ятниця",
+  "субота",
+];
+
+// How many days ahead the weekday lookup table covers. Two full weeks so a
+// "наступний <day>" mention always has an unambiguous row to match against,
+// even for the weekday that equals `today` itself.
+const WEEKDAY_TABLE_DAYS_AHEAD = 13;
+
+function pad2(value) {
+  return String(value).padStart(2, "0");
+}
+
+function addDaysToIsoDate(isoDate, days) {
+  const date = new Date(`${isoDate}T00:00:00.000Z`);
+  date.setUTCDate(date.getUTCDate() + days);
+  return `${date.getUTCFullYear()}-${pad2(date.getUTCMonth() + 1)}-${pad2(date.getUTCDate())}`;
+}
+
+function weekdayNameForIsoDate(isoDate) {
+  const date = new Date(`${isoDate}T00:00:00.000Z`);
+  return WEEKDAY_NAMES_UK[date.getUTCDay()];
+}
+
+/**
+ * Builds a deterministic "date = weekday name" lookup table starting at
+ * `today`. The model must resolve every weekday mention (понеділок, у
+ * суботу, наступної середи, etc.) by matching a row here instead of doing
+ * its own day-of-week arithmetic, which is the source of off-by-one errors.
+ */
+export function buildWeekdayReferenceBlock(today) {
+  const lines = [];
+  for (let offset = 0; offset <= WEEKDAY_TABLE_DAYS_AHEAD; offset += 1) {
+    const isoDate = addDaysToIsoDate(today, offset);
+    const weekday = weekdayNameForIsoDate(isoDate);
+    const marker = offset === 0 ? " (сьогодні)" : offset === 1 ? " (завтра)" : "";
+    lines.push(`${isoDate} = ${weekday}${marker}`);
+  }
+  return lines.join("\n");
+}
+
+export function buildParseUserMessage({ today, timeZone, text }) {
+  return (
+    `Локальна дата: ${today}\n` +
+    `Часовий пояс: ${timeZone}\n` +
+    `Дні тижня (використовуй лише цю таблицю для будь-якого дня тижня; не обчислюй день тижня самостійно):\n` +
+    `${buildWeekdayReferenceBlock(today)}\n` +
+    `Нотатка: ${text}`
+  );
+}
